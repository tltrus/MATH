 <Window x:Class="InterpolationVisualizer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InterpolationVisualizer"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:viewModels="clr-namespace:InterpolationVisualizer.ViewModels"
        xmlns:converters="clr-namespace:InterpolationVisualizer.Converters"
        mc:Ignorable="d"
        Title="Interpolation Methods" 
        Height="800" 
        Width="1300"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Color converter -->
        <converters:OxyColorToBrushConverter x:Key="OxyColorConverter"/>

        <!-- Styles -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="5,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left panel: Controls -->
        <Border Grid.Column="0" 
                Background="#FAFAFA" 
                BorderBrush="#DDDDDD" 
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Point management -->
                <GroupBox Grid.Row="1" 
                          Header="Data Management"
                          FontWeight="SemiBold">
                    <StackPanel>
                        <DataGrid x:Name="DataGridPoints"
                                  ItemsSource="{Binding DataPoints}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="True"
                                  CanUserDeleteRows="True"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  CanUserSortColumns="False"
                                  Height="180"
                                  Margin="0,0,0,10"
                                  BorderThickness="1"
                                  BorderBrush="#CCCCCC">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="X" 
                                                    Binding="{Binding X, StringFormat=N2}" 
                                                    Width="*"/>
                                <DataGridTextColumn Header="Y" 
                                                    Binding="{Binding Y, StringFormat=N2}" 
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Add Point" 
                                    Command="{Binding AddPointCommand}"
                                    ToolTip="Add random point"/>
                            <Button Content="Clear" 
                                    Command="{Binding ClearPointsCommand}"
                                    Background="#FF6B6B"
                                    Foreground="White"/>
                        </StackPanel>

                        <Separator Margin="0,10,0,5"/>

                        <TextBlock Text="Sample Data:" 
                                   FontWeight="SemiBold" 
                                   Margin="0,5"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Sin(x)" 
                                    Click="LoadSinData_Click"
                                    Width="80"/>
                            <Button Content="x²" 
                                    Click="LoadParabolaData_Click"
                                    Width="80"/>
                            <Button Content="Random" 
                                    Command="{Binding LoadSampleDataCommand}"
                                    Width="90"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Interpolation methods -->
                <GroupBox Grid.Row="2" 
                          Header="Interpolation Methods"
                          FontWeight="SemiBold">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  MaxHeight="300">
                        <ItemsControl ItemsSource="{Binding Methods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding Name}" 
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>

                                        <Border Grid.Column="2" 
                                                Width="20" 
                                                Height="20" 
                                                Margin="5"
                                                BorderBrush="Gray" 
                                                BorderThickness="1"
                                                VerticalAlignment="Center">
                                            <Rectangle Fill="{Binding Color, 
                                                       Converter={StaticResource OxyColorConverter}}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </GroupBox>

                <!-- Parameters -->
                <GroupBox Grid.Row="3" 
                          Header="Parameters"
                          FontWeight="SemiBold">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Interpolation step -->
                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="Interpolation Step:"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding InterpolationStep, StringFormat=N3}"
                                     ToolTip="Step for interpolation calculation"/>
                        </Grid>

                        <!-- Clamped spline parameters -->
                        <Grid Grid.Row="1" Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="Start Slope:"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding StartSlope, StringFormat=N2}"
                                     ToolTip="Start slope for clamped splines"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" 
                                       Text="End Slope:"/>
                            <TextBox Grid.Column="1" 
                                     Text="{Binding EndSlope, StringFormat=N2}"
                                     ToolTip="End slope for clamped splines"/>
                        </Grid>
                    </Grid>
                </GroupBox>
            </Grid>
        </Border>

        <!-- Right panel: Plot -->
        <Grid Grid.Column="1" Margin="10">
            <Border BorderBrush="#DDDDDD" 
                    BorderThickness="1" 
                    Background="White"
                    CornerRadius="3">
                <oxy:PlotView Model="{Binding PlotModel}"
                              Background="White"/>
            </Border>
        </Grid>
    </Grid>
</Window>