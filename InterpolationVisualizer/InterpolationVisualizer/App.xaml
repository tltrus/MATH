<Application x:Class="InterpolationVisualizer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:InterpolationVisualizer"
             xmlns:converters="clr-namespace:InterpolationVisualizer.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <!-- Конвертеры -->
        <converters:OxyColorToBrushConverter x:Key="OxyColorConverter"/>

        <!-- Стили по умолчанию -->
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Application.Resources>
</Application>